{
  "openapi": "3.0.3",
  "info": {
    "title": "Foundry W2 Tax Pipeline Tools",
    "version": "1.0.0",
    "description": "HTTP endpoints for the governed W-2 tax processing tools."
  },
  "servers": [
    {
      "url": "https://{functionAppHost}/api",
      "variables": {
        "functionAppHost": {
          "default": "replace-with-foundry-tools-function.azurewebsites.net"
        }
      }
    }
  ],
  "paths": {
    "/run-w2-pipeline": {
      "post": {
        "operationId": "run_w2_pipeline",
        "summary": "Run the complete W-2 pipeline.",
        "requestBody": {"$ref": "#/components/requestBodies/JsonToolPayload"},
        "responses": {"200": {"$ref": "#/components/responses/ToolResult"}}
      }
    },
    "/start-w2-pipeline": {
      "post": {
        "operationId": "start_w2_pipeline",
        "summary": "Create initial pipeline state.",
        "requestBody": {"$ref": "#/components/requestBodies/JsonToolPayload"},
        "responses": {"200": {"$ref": "#/components/responses/ToolResult"}}
      }
    },
    "/process-w2-intake": {
      "post": {
        "operationId": "process_w2_intake",
        "summary": "Process W-2 intake metadata.",
        "requestBody": {"$ref": "#/components/requestBodies/JsonToolPayload"},
        "responses": {"200": {"$ref": "#/components/responses/ToolResult"}}
      }
    },
    "/extract-w2-document": {
      "post": {
        "operationId": "extract_w2_document",
        "summary": "Extract normalized W-2 facts.",
        "requestBody": {"$ref": "#/components/requestBodies/JsonToolPayload"},
        "responses": {"200": {"$ref": "#/components/responses/ToolResult"}}
      }
    },
    "/validate-w2-facts": {
      "post": {
        "operationId": "validate_w2_facts",
        "summary": "Validate extracted W-2 facts.",
        "requestBody": {"$ref": "#/components/requestBodies/JsonToolPayload"},
        "responses": {"200": {"$ref": "#/components/responses/ToolResult"}}
      }
    },
    "/submit-w2-human-review": {
      "post": {
        "operationId": "submit_w2_human_review",
        "summary": "Route a flagged record to human review.",
        "requestBody": {"$ref": "#/components/requestBodies/JsonToolPayload"},
        "responses": {"200": {"$ref": "#/components/responses/ToolResult"}}
      }
    },
    "/map-w2-tax-facts": {
      "post": {
        "operationId": "map_w2_tax_facts",
        "summary": "Map W-2 facts to tax planning facts.",
        "requestBody": {"$ref": "#/components/requestBodies/JsonToolPayload"},
        "responses": {"200": {"$ref": "#/components/responses/ToolResult"}}
      }
    },
    "/generate-form-1040-document": {
      "post": {
        "operationId": "generate_form_1040_document",
        "summary": "Generate a draft Form 1040 document artifact.",
        "requestBody": {"$ref": "#/components/requestBodies/JsonToolPayload"},
        "responses": {"200": {"$ref": "#/components/responses/ToolResult"}}
      }
    },
    "/evaluate-w2-compliance": {
      "post": {
        "operationId": "evaluate_w2_compliance",
        "summary": "Evaluate compliance controls.",
        "requestBody": {"$ref": "#/components/requestBodies/JsonToolPayload"},
        "responses": {"200": {"$ref": "#/components/responses/ToolResult"}}
      }
    },
    "/persist-w2-pipeline-checkpoint": {
      "post": {
        "operationId": "persist_w2_pipeline_checkpoint",
        "summary": "Persist a governed pipeline checkpoint.",
        "requestBody": {"$ref": "#/components/requestBodies/JsonToolPayload"},
        "responses": {"200": {"$ref": "#/components/responses/ToolResult"}}
      }
    },
    "/persist-completed-w2-pipeline": {
      "post": {
        "operationId": "persist_completed_w2_pipeline",
        "summary": "Persist the completed governed pipeline state.",
        "requestBody": {"$ref": "#/components/requestBodies/JsonToolPayload"},
        "responses": {"200": {"$ref": "#/components/responses/ToolResult"}}
      }
    },
    "/get-runtime-configuration": {
      "post": {
        "operationId": "get_runtime_configuration",
        "summary": "Return non-secret runtime configuration.",
        "requestBody": {"$ref": "#/components/requestBodies/JsonToolPayload"},
        "responses": {"200": {"$ref": "#/components/responses/ToolResult"}}
      }
    }
  },
  "components": {
    "requestBodies": {
      "JsonToolPayload": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      }
    },
    "responses": {
      "ToolResult": {
        "description": "Tool execution result.",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": ["toolName", "result"],
              "properties": {
                "toolName": {"type": "string"},
                "result": {
                  "type": "object",
                  "additionalProperties": true
                }
              },
              "additionalProperties": true
            }
          }
        }
      }
    }
  }
}
