{
  "openapi": "3.0.3",
  "info": {
    "title": "Foundry W2 Tax Pipeline Tools",
    "version": "1.0.0",
    "description": "HTTP endpoints for the governed W-2 tax processing tools."
  },
  "servers": [
    {
      "url": "https://{functionAppHost}/api",
      "variables": {
        "functionAppHost": {
          "default": "replace-with-foundry-tools-function.azurewebsites.net"
        }
      }
    }
  ],
  "paths": {
    "/run-w2-pipeline": {
      "post": {
        "operationId": "run_w_two_pipeline",
        "summary": "Run the complete W-2 pipeline.",
        "requestBody": {"$ref": "#/components/requestBodies/StartPipelineBody"},
        "responses": {"200": {"$ref": "#/components/responses/ToolResult"}}
      }
    },
    "/start-w2-pipeline": {
      "post": {
        "operationId": "start_w_two_pipeline",
        "summary": "Create initial pipeline state.",
        "requestBody": {"$ref": "#/components/requestBodies/StartPipelineBody"},
        "responses": {"200": {"$ref": "#/components/responses/ToolResult"}}
      }
    },
    "/process-w2-intake": {
      "post": {
        "operationId": "process_w_two_intake",
        "summary": "Process W-2 intake metadata.",
        "requestBody": {"$ref": "#/components/requestBodies/PipelineStateBody"},
        "responses": {"200": {"$ref": "#/components/responses/ToolResult"}}
      }
    },
    "/extract-w2-document": {
      "post": {
        "operationId": "extract_w_two_document",
        "summary": "Extract normalized W-2 facts.",
        "requestBody": {"$ref": "#/components/requestBodies/PipelineStateBody"},
        "responses": {"200": {"$ref": "#/components/responses/ToolResult"}}
      }
    },
    "/validate-w2-facts": {
      "post": {
        "operationId": "validate_w_two_facts",
        "summary": "Validate extracted W-2 facts.",
        "requestBody": {"$ref": "#/components/requestBodies/PipelineStateBody"},
        "responses": {"200": {"$ref": "#/components/responses/ToolResult"}}
      }
    },
    "/submit-w2-human-review": {
      "post": {
        "operationId": "submit_w_two_human_review",
        "summary": "Route a flagged record to human review.",
        "requestBody": {"$ref": "#/components/requestBodies/PipelineStateBody"},
        "responses": {"200": {"$ref": "#/components/responses/ToolResult"}}
      }
    },
    "/map-w2-tax-facts": {
      "post": {
        "operationId": "map_w_two_tax_facts",
        "summary": "Map W-2 facts to tax planning facts.",
        "requestBody": {"$ref": "#/components/requestBodies/PipelineStateBody"},
        "responses": {"200": {"$ref": "#/components/responses/ToolResult"}}
      }
    },
    "/generate-form-1040-document": {
      "post": {
        "operationId": "generate_form_ten_forty_document",
        "summary": "Generate a draft Form 1040 document artifact.",
        "requestBody": {"$ref": "#/components/requestBodies/PipelineStateBody"},
        "responses": {"200": {"$ref": "#/components/responses/ToolResult"}}
      }
    },
    "/evaluate-w2-compliance": {
      "post": {
        "operationId": "evaluate_w_two_compliance",
        "summary": "Evaluate compliance controls.",
        "requestBody": {"$ref": "#/components/requestBodies/PipelineStateBody"},
        "responses": {"200": {"$ref": "#/components/responses/ToolResult"}}
      }
    },
    "/persist-w2-pipeline-checkpoint": {
      "post": {
        "operationId": "persist_w_two_pipeline_checkpoint",
        "summary": "Persist a governed pipeline checkpoint.",
        "requestBody": {"$ref": "#/components/requestBodies/CheckpointBody"},
        "responses": {"200": {"$ref": "#/components/responses/ToolResult"}}
      }
    },
    "/persist-completed-w2-pipeline": {
      "post": {
        "operationId": "persist_completed_w_two_pipeline",
        "summary": "Persist the completed governed pipeline state.",
        "requestBody": {"$ref": "#/components/requestBodies/CompletedPipelineBody"},
        "responses": {"200": {"$ref": "#/components/responses/ToolResult"}}
      }
    },
    "/get-runtime-configuration": {
      "post": {
        "operationId": "get_runtime_configuration",
        "summary": "Return non-secret runtime configuration.",
        "requestBody": {"$ref": "#/components/requestBodies/GenericPayloadBody"},
        "responses": {"200": {"$ref": "#/components/responses/ToolResult"}}
      }
    }
  },
  "components": {
    "schemas": {
      "StartPipelinePayload": {
        "type": "object",
        "required": ["tenantId", "taxpayerId", "documentName", "blobUri", "taxYear"],
        "properties": {
          "correlationId": {
            "type": "string",
            "description": "Optional unique correlation ID for traceability."
          },
          "tenantId": {
            "type": "string",
            "description": "Unique identifier of the tenant owner."
          },
          "taxpayerId": {
            "type": "string",
            "description": "Unique identifier of the taxpayer."
          },
          "documentName": {
            "type": "string",
            "description": "Original filename of the W-2 document."
          },
          "blobUri": {
            "type": "string",
            "description": "Secure Azure Blob storage URI of the uploaded document."
          },
          "taxYear": {
            "type": "integer",
            "description": "Tax year associated with the W-2 document."
          },
          "mockExtractionOverrides": {
            "type": "object",
            "description": "Optional mocked values to override extraction data."
          }
        },
        "additionalProperties": true
      },
      "PipelineStatePayload": {
        "type": "object",
        "required": ["correlationId"],
        "properties": {
          "pipelineId": {"type": "string"},
          "correlationId": {"type": "string"},
          "tenantId": {"type": "string"},
          "taxpayerId": {"type": "string"},
          "documentName": {"type": "string"},
          "blobUri": {"type": "string"},
          "taxYear": {"type": "integer"},
          "stage": {"type": "string"},
          "status": {"type": "string"},
          "intakeResult": {"type": "object"},
          "extractionResult": {"type": "object"},
          "validationResult": {"type": "object"},
          "humanReviewResult": {"type": "object"},
          "mappingResult": {"type": "object"},
          "formGenerationResult": {"type": "object"},
          "finalResult": {"type": "object"}
        },
        "additionalProperties": true
      }
    },
    "requestBodies": {
      "StartPipelineBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/StartPipelinePayload"
            }
          }
        }
      },
      "PipelineStateBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/PipelineStatePayload"
            }
          }
        }
      },
      "CheckpointBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": ["state", "checkpointStage"],
              "properties": {
                "checkpointStage": {"type": "string"},
                "state": {"$ref": "#/components/schemas/PipelineStatePayload"}
              }
            }
          }
        }
      },
      "CompletedPipelineBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": ["state"],
              "properties": {
                "state": {"$ref": "#/components/schemas/PipelineStatePayload"}
              }
            }
          }
        }
      },
      "GenericPayloadBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      }
    },
    "responses": {
      "ToolResult": {
        "description": "Tool execution result.",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": ["toolName", "result"],
              "properties": {
                "toolName": {"type": "string"},
                "result": {
                  "type": "object",
                  "additionalProperties": true
                }
              },
              "additionalProperties": true
            }
          }
        }
      }
    }
  }
}
