# Local development defaults for the Foundry agent pipeline.
# Copy to .env for local use if your tooling loads .env files, or set these
# values directly in your shell, IDE launch profile, Azure app settings, or
# Foundry hosted agent environment.

APP_ENV=local

# Foundry prompt agent model deployment
AZURE_OPENAI_DEPLOYMENT_NAME=

# Extraction
# local: deterministic offline adapter for development/tests
# document-intelligence: Azure AI Document Intelligence adapter
W2_EXTRACTION_MODE=local
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
AZURE_DOCUMENT_INTELLIGENCE_MODEL_ID=prebuilt-tax.us.w2

# Validation
W2_VALIDATION_STRICTNESS=standard
LOW_CONFIDENCE_THRESHOLD=0.85

# Human review
# local-auto-approve: lets local tests continue
# queue/manual: pauses pipeline until human decision is recorded
HUMAN_REVIEW_MODE=local-auto-approve

# Tax mapping
TAX_MAPPING_PROFILE=us-federal-2024

# Compliance and audit
COMPLIANCE_MODE=development
REQUIRE_MASKED_PII_IN_LOGS=true
AUDIT_EVENT_ENABLED=true

# Governed tax fact persistence
# disabled: do not persist normalized tax facts
# local-json: write governed JSON records under TAX_FACT_PERSISTENCE_PATH for local development
# cosmos: upsert governed checkpoints to Azure Cosmos DB
TAX_FACT_PERSISTENCE_MODE=local-json
TAX_FACT_PERSISTENCE_PATH=.local_state/tax-facts
AZURE_COSMOS_ENDPOINT=
AZURE_COSMOS_DATABASE_NAME=tax-intelligence
AZURE_COSMOS_CONTAINER_NAME=tax-facts
AZURE_COSMOS_KEY=
ALLOW_FULL_PII_PERSISTENCE=false
